# Database (Neon/Postgres)
DATABASE_URL="postgres://user:password@host:port/db"

# Session cookies
SESSION_SECRET="at-least-32-characters"

# Supabase Storage (profile avatars)
# Find these in: Supabase dashboard → Settings → Storage → S3 Access
SUPABASE_S3_ENDPOINT="https://your-project-ref.supabase.co/storage/v1/s3"
SUPABASE_S3_REGION="us-east-1"
SUPABASE_S3_ACCESS_KEY_ID="your-access-key-id"
SUPABASE_S3_SECRET_ACCESS_KEY="your-secret-access-key"
SUPABASE_STORAGE_BUCKET="avatars"
# Public base URL for serving files (no trailing slash, no bucket name)
# e.g. https://your-project-ref.supabase.co/storage/v1/object/public
SUPABASE_STORAGE_PUBLIC_URL="https://your-project-ref.supabase.co/storage/v1/object/public"
# Optional key prefix inside the bucket (leave empty to store at root)
SUPABASE_STORAGE_AVATAR_PREFIX=""
